# ── Server ───────────────────────────────────────────────
PORT=3000

# ── Notion (optional — enables cross-device progress sync) ─
# Create an internal integration at https://www.notion.so/my-integrations
# then copy its token here (starts with "ntn_" or "secret_").
NOTION_TOKEN=

# EITHER point at an existing database the integration can edit…
NOTION_DATABASE_ID=
# …OR give a parent page (shared with the integration) and the app
# will create the progress database under it on first run.
NOTION_PARENT_PAGE_ID=

# ── AI tutor (optional) ──────────────────────────────────
# If set, the AI tutor uses this key and users don't need to paste one.
# Leave blank to let each user paste their own key in the browser.
ANTHROPIC_API_KEY=
# Override the model the tutor uses (default: claude-opus-4-8).
# Cheaper options: claude-haiku-4-5, claude-sonnet-4-6
AI_MODEL=claude-opus-4-8
