# ── Server ───────────────────────────────────────────────
PORT=3000

# ── Notion (enables real data) ───────────────────────────
# Without a token the app still runs, in browser-local demo mode.
# 1. Create an internal integration at https://www.notion.so/my-integrations
# 2. Copy its token here (starts with "ntn_" or "secret_").
# 3. Open your 💰 Money Trackers page in Notion → ••• → Connections →
#    add your integration. Sharing the parent page grants access to the child
#    databases (Incomes, Expenses, Accounts, Categories).
NOTION_TOKEN=

# ── Optional: gate the API behind a shared password ──────
# If set, the browser must enter this token once (stored locally) to unlock
# the app, and every API request must carry it. Leave blank on localhost.
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
APP_TOKEN=

# ── Optional: override the bundled database IDs ──────────
# Defaults live in server/config.js. Uncomment to point at your own databases.
# DB_EXPENSES=
# DB_INCOMES=
# DB_ACCOUNTS=
# DB_EXPENSE_CATEGORIES=
# DB_INCOME_CATEGORIES=
