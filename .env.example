# ── Database ─────────────────────────────────────────────
# Postgres connection string.
#  • Set it  → the app uses it (Neon in production, or any Postgres locally).
#  • Empty   → the app falls back to an embedded Postgres (PGlite) stored in
#              ./.pglite, auto-migrated and seeded. Zero setup for local dev.
#
# Create a free database at https://neon.tech, then paste its *pooled*
# connection string here (and into Vercel's Environment Variables for prod):
DATABASE_URL=

# ── Email (verification, invites, password reset) ────────
# Used to send email-verification, sharing-invite, and "forgot password" links.
# Without a key, those emails are printed to the server console (fine for local
# dev). Get a free key at resend.com.
RESEND_API_KEY=
EMAIL_FROM=Money Tracker <onboarding@resend.dev>
# Base URL used in the links inside those emails (auto-detected if left blank).
APP_URL=

# ── Cron (recurring transactions) ────────────────────────
# Protects the daily /api/cron/recurring job (see vercel.json). Set the same
# value here and in Vercel; Vercel Cron sends it as `Authorization: Bearer …`.
# If left blank, the endpoint is unauthenticated (fine for local dev).
CRON_SECRET=

# ── Display (optional) ───────────────────────────────────
# Currency symbol + locale used when formatting amounts.
NEXT_PUBLIC_CURRENCY=₹
NEXT_PUBLIC_LOCALE=en-IN
